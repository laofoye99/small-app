# =============================================================================
#  Tennis Analysis Pipeline — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Model weights  (large binaries — copy manually to new machine)
# -----------------------------------------------------------------------------
model_weights/*.pt
model_weights/*.pth
model_weights/*.pth.tar
model_weights/*.onnx
# Keep the directory itself
!model_weights/.gitkeep

# -----------------------------------------------------------------------------
# Input / upload media  (large video files — not versioned)
# Never commit raw footage; calibration JSONs ARE committed (small + needed)
# -----------------------------------------------------------------------------
uploads/*.mp4
uploads/*.avi
uploads/*.mov
uploads/*.mkv
# Keep calibration and homography JSONs
!uploads/cal_*.json
!uploads/homography_matrices.json

# -----------------------------------------------------------------------------
# Generated output  (all regenerated by running the pipeline)
# -----------------------------------------------------------------------------
output/
output_backup/
result.json

# -----------------------------------------------------------------------------
# Python cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Claude Code local settings  (machine-specific, not shared)
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
logs/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
